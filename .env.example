# ════════════════════════════════════════════════════════════
#  WageWise – Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  Never commit the .env file to version control.
# ════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Local LLM – Primary (Ollama or OpenAI-compatible) ────────
LLM_PROVIDER=ollama                      # "ollama" | "openai"
LLM_BASE_URL=http://localhost:11434      # Ollama default; change for remote/openai
LLM_MODEL=llama3.1:8b                   # model tag pulled in Ollama
LLM_TIMEOUT=120                         # seconds before giving up on local LLM

# ── Google Gemini (Fallback LLM) ─────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Backend (FastAPI) ─────────────────────────────────────────
# Use http://10.0.2.2:8000 for Android emulator (maps to host localhost)
# Use your LAN IP (e.g. http://192.168.1.x:8000) for physical device
BACKEND_URL=http://10.0.2.2:8000
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost,http://10.0.2.2

# ── Machine Learning ──────────────────────────────────────────
MODEL_PATH=./models/salary_model.pkl
ENCODER_PATH=./models/label_encoders.pkl

# ── ChromaDB (Vector Store for RAG) ──────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=wagewise_legal_docs

# ── HuggingFace ───────────────────────────────────────────────
HF_DATASET=azrai99/job-dataset
HF_TOKEN=                        # optional, only for private datasets

# ── App Settings ──────────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=info
