<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext traffic to localhost and 10.0.2.2 (Android emulator host)
  during development. Production builds should remove the domain-config block
  and rely on the default HTTPS-only policy.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
